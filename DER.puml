@startuml
!theme toy
hide circle
skinparam linetype ortho

entity Pais {
  pai_id : int <<PK, IDENTITY>>
  --
  pai_nombre : nvarchar(255)
}

entity Provincia {
  pro_id : int <<PK, IDENTITY>>
  --
  pro_pais : int <<FK>>
  pro_nombre : nvarchar(255)
}

entity Localidad {
  loc_id : int <<PK, IDENTITY>>
  --
  loc_provincia : int <<FK>>
  loc_nombre : nvarchar(255)
}

entity Ciudad {
  ciu_id : int <<PK, IDENTITY>>
  --
  ciu_pais : int <<FK>>
  ciu_nombre : nvarchar(255)
}

entity Alianza {
  ali_id : int <<PK, IDENTITY>>
  --
  ali_descripcion : nvarchar(255)
}

entity Estado_Propuesta {
  esp_id : int <<PK, IDENTITY>>
  --
  esp_descripcion : nvarchar(255)
}

entity CanalVenta {
  cdv_id : int <<PK, IDENTITY>>
  --
  cdv_descripcion : nvarchar(255)
}

entity MedioPago {
  mdp_id : int <<PK, IDENTITY>>
  --
  mdp_descripcion : nvarchar(255)
}

entity Aspecto_Encuesta {
  asp_id : int <<PK, IDENTITY>>
  --
  asp_descripcion : nvarchar(255)
}

entity Agencia {
  age_nro_agencia : bigint <<PK>>
  --
  age_localidad : int <<FK>>
  age_direccion : nvarchar(255)
  age_telefono : nvarchar(255)
  age_mail : nvarchar(255)
}

entity Agente {
  agt_legajo : bigint <<PK>>
  --
  agt_agencia : bigint <<FK>>
  agt_localidad : int <<FK>>
  agt_dni : nvarchar(255)
  agt_nombre : nvarchar(255)
  agt_apellido : nvarchar(255)
  agt_fecha_nacimiento : date
  agt_mail : nvarchar(255)
  agt_telefono : nvarchar(255)
  agt_direccion : nvarchar(255)
}

entity Cliente {
  cli_id : int <<PK, IDENTITY>>
  --
  cli_localidad : int <<FK>>
  cli_dni : nvarchar(255)
  cli_nombre : nvarchar(255)
  cli_apellido : nvarchar(255)
  cli_fecha_nacimiento : date
  cli_mail : nvarchar(255)
  cli_telefono : nvarchar(255)
  cli_direccion : nvarchar(255)
}

entity Aerolinea {
  aero_codigo : nvarchar(255) <<PK>>
  --
  aero_pais : int <<FK>>
  aero_alianza : int <<FK>>
  aero_nombre : nvarchar(255)
}

entity Aeropuerto {
  aer_codigo : nvarchar(10) <<PK>>
  --
  aer_ciudad : int <<FK>>
  aer_descripcion : nvarchar(200)
}

entity Vuelo {
  vue_id : int <<PK, IDENTITY>>
  --
  vue_aerolinea : nvarchar(255) <<FK>>
  vue_aeropuerto_salida : nvarchar(10) <<FK>>
  vue_aeropuerto_llegada : nvarchar(10) <<FK>>
  vue_fecha_salida : date
  vue_hora_salida : nvarchar(50)
  vue_fecha_llegada : date
  vue_hora_llegada : nvarchar(50)
  vue_duracion : int
  vue_precio : decimal(18,2)
  vue_incluye_carry : bit
  vue_incluye_valija : bit
}

entity Hospedaje {
  hos_id : int <<PK, IDENTITY>>
  --
  hos_ciudad : int <<FK>>
  hos_nombre : nvarchar(255)
  hos_direccion : nvarchar(255)
  hos_horario_checkin : nvarchar(50)
  hos_horario_checkout : nvarchar(50)
  hos_incluye_desayuno : bit
}

entity Tipo_Habitacion {
  tdh_id : int <<PK, IDENTITY>>
  --
  tdh_hospedaje : int <<FK>>
  tdh_nombre : nvarchar(255)
  tdh_descripcion : nvarchar(max)
  tdh_cant_camas : int
  tdh_precio_base : decimal(18,2)
}

entity Proveedor_Excursion {
  pre_id : int <<PK, IDENTITY>>
  --
  pre_nombre : nvarchar(255)
  pre_mail : nvarchar(255)
  pre_telefono : nvarchar(255)
}

entity Excursion {
  exc_id : int <<PK, IDENTITY>>
  --
  exc_proveedor : int <<FK>>
  exc_ciudad : int <<FK, nullable>>
  exc_nombre : nvarchar(255)
  exc_descripcion : nvarchar(max)
  exc_duracion : int
  exc_horario : nvarchar(50)
  exc_precio : decimal(18,2)
}

entity Venta {
  ven_nro_venta : bigint <<PK>>
  --
  ven_cliente : int <<FK>>
  ven_agente : bigint <<FK>>
  ven_canal_venta : int <<FK>>
  ven_medio_pago : int <<FK>>
  ven_propuesta : bigint <<FK, nullable>>
  ven_fecha : date
  ven_subtotal : decimal(18,2)
  ven_descuento : decimal(18,2)
  ven_total : decimal(18,2)
}

entity Venta_Vuelo {
  vv_id : int <<PK, IDENTITY>>
  --
  vv_venta : bigint <<FK>>
  vv_vuelo : int <<FK>>
  vv_cant_pasajes : int
  vv_precio : decimal(18,2)
  vv_subtotal : decimal(18,2)
  vv_codigo_reserva : nvarchar(255)
}

entity Venta_Hospedaje {
  vh_id : int <<PK, IDENTITY>>
  --
  vh_venta : bigint <<FK>>
  vh_tipo_habitacion : int <<FK>>
  vh_fecha_desde : date
  vh_fecha_hasta : date
  vh_cantidad : int
  vh_precio : decimal(18,2)
  vh_subtotal : decimal(18,2)
  vh_codigo_reserva : nvarchar(255)
}

entity Venta_Excursion {
  ve_id : int <<PK, IDENTITY>>
  --
  ve_venta : bigint <<FK>>
  ve_excursion : int <<FK>>
  ve_fecha : date
  ve_cantidad : int
  ve_precio : decimal(18,2)
  ve_subtotal : decimal(18,2)
  ve_codigo_reserva : nvarchar(255)
}

entity Solicitud_Cotizacion {
  sol_nro : bigint <<PK>>
  --
  sol_cliente : int <<FK>>
  sol_agente : bigint <<FK>>
  sol_fecha_solicitud : date
  sol_fecha_inicio_tentativa : date
  sol_fecha_fin_tentativa : date
  sol_cant_pasajeros : int
  sol_presupuesto : decimal(18,2)
  sol_observaciones : nvarchar(max)
}

entity Detalle_Solicitud {
  ds_id : int <<PK, IDENTITY>>
  --
  ds_solicitud : bigint <<FK>>
  ds_ciudad : int <<FK>>
  ds_cant_dias : int
  ds_observaciones : nvarchar(max)
}

entity Propuesta {
  prop_nro_propuesta : bigint <<PK>>
  --
  prop_solicitud : bigint <<FK>>
  prop_agente : bigint <<FK>>
  prop_estado : int <<FK>>
  prop_fecha : date
  prop_vigencia : date
  prop_fecha_desde : date
  prop_fecha_hasta : date
  prop_subtotal : decimal(18,2)
  prop_descuento : decimal(18,2)
  prop_total : decimal(18,2)
}

entity Propuesta_Vuelo {
  pv_id : int <<PK, IDENTITY>>
  --
  pv_propuesta : bigint <<FK>>
  pv_vuelo : int <<FK>>
  pv_cantidad : int
  pv_precio : decimal(18,2)
  pv_subtotal : decimal(18,2)
}

entity Propuesta_Hospedaje {
  ph_id : int <<PK, IDENTITY>>
  --
  ph_propuesta : bigint <<FK>>
  ph_tipo_habitacion : int <<FK>>
  ph_fecha_desde : date
  ph_fecha_hasta : date
  ph_cant_habitaciones : int
  ph_precio : decimal(18,2)
  ph_subtotal : decimal(18,2)
}

entity Encuesta {
  enc_id : bigint <<PK>>
  --
  enc_cliente : int <<FK>>
  enc_agente : bigint <<FK>>
  enc_venta : bigint <<FK, nullable>>
  enc_solicitud : bigint <<FK, nullable>>
  enc_fecha : date
  enc_comentario : nvarchar(max)
}

entity Valoracion_Encuesta {
  val_id : int <<PK, IDENTITY>>
  --
  val_encuesta : bigint <<FK>>
  val_aspecto : int <<FK>>
  val_puntaje : int
}

' --- Geografia ---
Pais ||--o{ Provincia
Provincia ||--o{ Localidad
Pais ||--o{ Ciudad

' --- Localidad a personas/org ---
Localidad ||--o{ Agencia
Localidad ||--o{ Agente
Localidad ||--o{ Cliente

' --- Catalogos a Aerolinea ---
Pais ||--o{ Aerolinea
Alianza ||--o{ Aerolinea

' --- Ciudad a productos turisticos ---
Ciudad ||--o{ Aeropuerto
Ciudad ||--o{ Hospedaje
Ciudad |o--o{ Excursion
Ciudad ||--o{ Detalle_Solicitud

' --- Agencia / Agente ---
Agencia ||--o{ Agente

' --- Productos base ---
Aerolinea ||--o{ Vuelo
Aeropuerto ||--o{ Vuelo
Hospedaje ||--o{ Tipo_Habitacion
Proveedor_Excursion ||--o{ Excursion

' --- Ventas ---
Cliente ||--o{ Venta
Agente ||--o{ Venta
CanalVenta ||--o{ Venta
MedioPago ||--o{ Venta
Propuesta |o--o{ Venta

Venta ||--o{ Venta_Vuelo
Venta ||--o{ Venta_Hospedaje
Venta ||--o{ Venta_Excursion

Vuelo ||--o{ Venta_Vuelo
Tipo_Habitacion ||--o{ Venta_Hospedaje
Excursion ||--o{ Venta_Excursion

' --- Solicitudes y propuestas ---
Cliente ||--o{ Solicitud_Cotizacion
Agente ||--o{ Solicitud_Cotizacion
Solicitud_Cotizacion ||--o{ Detalle_Solicitud
Solicitud_Cotizacion ||--o{ Propuesta

Agente ||--o{ Propuesta
Estado_Propuesta ||--o{ Propuesta

Propuesta ||--o{ Propuesta_Vuelo
Propuesta ||--o{ Propuesta_Hospedaje

Vuelo ||--o{ Propuesta_Vuelo
Tipo_Habitacion ||--o{ Propuesta_Hospedaje

' --- Encuestas ---
Cliente ||--o{ Encuesta
Agente ||--o{ Encuesta
Venta |o--o{ Encuesta
Solicitud_Cotizacion |o--o{ Encuesta

Encuesta ||--o{ Valoracion_Encuesta
Aspecto_Encuesta ||--o{ Valoracion_Encuesta
@enduml
